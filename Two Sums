class Solution(object):
    def twoSum(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: List[int]
        """
        seen = {}

        
        for i, num in enumerate(nums):
            need = target - num

            if num in seen:
                return [i, seen[num]]
            else:
                seen[need] = i
        

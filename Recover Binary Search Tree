class Solution {
private:
    TreeNode* first = nullptr;
    TreeNode* second = nullptr;
    TreeNode* prev = new TreeNode(LONG_MIN); 

public:
    void inorder(TreeNode* root) {
        if (!root) return;

        inorder(root->left);

       
        if (root->val < prev->val) {
           
            if (first == nullptr) {
                first = prev;
            }
         
            second = root;
        }
        prev = root;

        inorder(root->right);
    }

    void recoverTree(TreeNode* root) {
        inorder(root);
       
        int temp = first->val;
        first->val = second->val;
        second->val = temp;
    }
};
